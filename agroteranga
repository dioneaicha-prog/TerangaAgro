/// =====================================================
/// SESSION UTILISATEUR (connexion / inscription)
/// =====================================================
class UserSession extends ChangeNotifier {
  UserSession._();
  static final UserSession instance = UserSession._();

  String? nom;
  String? telephone;
  String role = 'Acheteur'; // 'Acheteur' ou 'Producteur'

  bool get isLoggedIn => nom != null && nom!.isNotEmpty;

  void login({required String nom, required String telephone, required String role}) {
    this.nom = nom;
    this.telephone = telephone;
    this.role = role;
    notifyListeners();
  }

  void logout() {
    nom = null;
    telephone = null;
    notifyListeners();
  }
}

