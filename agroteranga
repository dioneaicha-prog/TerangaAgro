/// Widget d'image produit : affiche la vraie photo (assets/images/...) si
/// disponible, sinon une vignette de secours colorée avec une icône —
/// jamais de photo générique aléatoire non liée au produit.
class RealProductImage extends StatelessWidget {
  final Product product;
  final double? width;
  final double? height;
  final BoxFit fit;
  final BorderRadius? borderRadius;

  const RealProductImage({
    super.key,
    required this.product,
    this.width,
    this.height,
    this.fit = BoxFit.cover,
    this.borderRadius,
  });

  @override
  Widget build(BuildContext context) {
    Widget fallback = Container(
      width: width,
      height: height,
      color: product.fallbackColor,
      child: Icon(product.fallbackIcon, color: Colors.black45, size: (height ?? 80) * 0.35),
    );

    Widget content;
    if (product.imageUrl != null) {
      content = Image.network(
        product.imageUrl!,
        width: width,
        height: height,
        fit: fit,
        errorBuilder: (_, __, ___) => fallback,
        loadingBuilder: (context, child, progress) {
          if (progress == null) return child;
          return Container(
            width: width,
            height: height,
            color: product.fallbackColor.withValues(alpha: 0.4),
            child: const Center(child: SizedBox(width: 18, height: 18, child: CircularProgressIndicator(strokeWidth: 2))),
          );
        },
      );
    } else if (product.imageAsset != null) {
      content = Image.asset(
        product.imageAsset!,
        width: width,
        height: height,
        fit: fit,
        errorBuilder: (_, __, ___) => fallback,
      );
    } else {
      content = fallback;
    }

    if (borderRadius != null) {
      return ClipRRect(borderRadius: borderRadius!, child: content);
    }
    return content;
  }
}

